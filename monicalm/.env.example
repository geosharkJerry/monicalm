# ----- Next.js BFF -----
# HMAC secret that signs the monicalm_session JWT. MUST be identical to the
# value configured as SESSION_SECRET on the Cloudflare Worker.
SESSION_SECRET=change-me-to-32+-random-bytes

# Where the Go new-api backend lives. The BFF and the Worker both proxy here.
NEW_API_BASE_URL=http://127.0.0.1:3000

# ----- Cloudflare edge integration (optional) -----
# Public URL of the deployed Worker. Used by Next.js Edge routes to fetch
# personalized state and (optionally) to forward chat traffic.
EDGE_GATEWAY_URL=https://gateway.monicalm.example
NEXT_PUBLIC_EDGE_GATEWAY_URL=https://gateway.monicalm.example

# Internal token shared by Go ↔ Worker ↔ Next.js Edge for the /internal/* APIs.
CF_INTERNAL_TOKEN=change-me-internal-token
